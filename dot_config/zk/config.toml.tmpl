{{- /* chezmoi:template:left-delimiter=[[ right-delimiter=]] */ -}}
# NOTEBOOK SETTINGS
[notebook]
dir = "~/notebook"

# NOTE SETTINGS
[note]
language = "en"
default-title = "Untitled"
filename = "{{format-date now 'timestamp'}}{{#if extra.prefix}}-{{extra.prefix}}{{/if}}-{{slug title}}"
extension = "md"
template = "[[ .chezmoi.homeDir ]]/.config/zk/templates/default.md"

id-charset = "alphanum"
id-length = 4
id-case = "lower"

[extra]
author = "Felix Brousseau-Tremblay"

# GROUP OVERRIDES

[group.daily-personal]
paths = ["journal/personal"]

[group.daily-personal.note]
filename = "{{format-date now '%Y-%m-%d'}}"
extension = "md"
template = "[[ .chezmoi.homeDir ]]/.config/zk/templates/daily-personal.md"

[group.daily-work]
paths = ["journal/work"]

[group.daily-work.note]
filename = "{{format-date now '%Y-%m-%d'}}"
extension = "md"
template = "[[ .chezmoi.homeDir ]]/.config/zk/templates/daily-work.md"

# MARKDOWN SETTINGS
[format.markdown]
link-format = "wiki"
hashtags = true
colon-tags = true

# EXTERNAL TOOLS
[tool]
editor = "nvim"
pager = "less -FIRX"
fzf-preview = "bat -p --color always {-1}"

# NAMED FILTERS
[filter]
recents = "--sort created- --created-after 'last two weeks'"

# COMMAND ALIASES
[alias]
edlast = "zk edit --limit 1 --sort modified- $@"
recent = "zk edit --sort created- --created-after 'last two weeks' --interactive"
lucky = "zk list --quiet --format full --sort random --limit 1"

daily = '''
case "$1" in
  personal) zk new --no-input "$ZK_NOTEBOOK_DIR/journal/personal" ;;
  work)     zk new --no-input "$ZK_NOTEBOOK_DIR/journal/work" ;;
  "")       echo "usage: zk daily {personal|work}" >&2; exit 2 ;;
  *)        echo "zk daily: unknown kind '$1' (use 'personal' or 'work')" >&2; exit 2 ;;
esac
'''

# LSP
[lsp]

[lsp.diagnostics]
wiki-title = "hint"
dead-link = "error"
