font-size = 16
theme = active-theme
mouse-hide-while-typing = true
background-opacity = 0.9
background-blur = true
window-padding-x = 5
window-padding-balance = true

clipboard-paste-protection = false

macos-icon = retro
macos-option-as-alt = true

# Pass Alt+Arrow through to terminal apps (e.g. Zellij pane navigation)
keybind = opt+left=text:\x1b[1;3D
keybind = opt+right=text:\x1b[1;3C
keybind = opt+up=text:\x1b[1;3A
keybind = opt+down=text:\x1b[1;3B

# SHELL
command = /opt/homebrew/bin/nu
shell-integration = none
